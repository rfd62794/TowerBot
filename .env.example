# PrivyBot — environment variables
# Copy to .env and fill in values

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

OPENROUTER_API_KEY=your_openrouter_api_key

# Google OAuth token paths (generated by scripts/youtube_auth.py and scripts/rfd_auth.py)
YOUTUBE_TOKEN_PATH=config/youtube_token.json
YOUTUBE_CLIENT_SECRETS=config/client_secret.json
RFD_GMAIL_TOKEN_PATH=config/rfd_token.json

# Steam
STEAM_API_KEY=your_steam_api_key
STEAM_USER_ID=your_steam_user_id

# IsThereAnyDeal
ITAD_API_KEY=your_itad_api_key

# Weather (Open-Meteo requires no key — lat/lon only)
WEATHER_LAT=25.7617
WEATHER_LON=-80.1918

# Ollama local inference
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_ENABLED=false
OLLAMA_VRAM_GB=4.0   # RTX 3050 Ti — change for Tower or other hardware

# PrivyBot mode (dev or production)
PRIVYBOT_MODE=production

# MCP server JWT secret (for SSE transport auth)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_JWT_SECRET=your_mcp_jwt_secret_here
